# Diese Datei ist eine Vorlage.
# Auf Linux/Proxmox nach .env.local kopieren und Werte eintragen.
# .env.local nicht weitergeben und nicht in Chats posten.

SPM_USERNAME=dein_benutzer
SPM_PASSWORD=dein_passwort

# Optional, normalerweise leer lassen.
# Wenn Benutzer/Passwort gesetzt sind, wird SPM_COOKIE ignoriert.
SPM_COOKIE=
