# Dieses Beispiel kannst du auf dem Host nach .env kopieren.
# Keine echten Passwoerter in GitHub committen.

# Von wo soll der Mapper-Code geladen werden?
# Empfehlung: GitHub Repo als tar.gz, z.B.
# MAPPER_ARCHIVE_URL=https://github.com/DEINNAME/spm-tvg-mapper/archive/refs/heads/main.tar.gz
MAPPER_ARCHIVE_URL=

# Zielordner auf dem Host.
INSTALL_DIR=/opt/spm-tvg-mapper

# Mapper-WebUI.
WEB_PORT=8099

# Produktiv-SPM.
SPM_TARGET_NAME=Produktiv SPM
SPM_BASE_URL=http://10.10.100.117:8000
SPM_USERNAME=
SPM_PASSWORD=
SPM_PROFILE_NAME=spm

# Optional: EasyEPG settings.json uebernehmen.
# Empfehlung: Datei privat auf Unraid/NAS bereitstellen, nicht oeffentlich auf GitHub.
# Beispiel:
# EASYEPG_SETTINGS_URL=http://unraid.local/share/easyepg/settings.json
EASYEPG_SETTINGS_URL=

# Optional: Wenn EasyEPG lokal als Docker-Container laeuft.
# Der Installer kopiert settings.json in den Containerpfad und erstellt vorher ein Backup.
EASYEPG_CONTAINER=
EASYEPG_SETTINGS_PATH=/opt/EasyEPG/settings.json

# Optional: Wenn EasyEPG settings.json direkt auf dem Host liegt.
# Beispiel: /mnt/user/appdata/easyepg/settings.json
EASYEPG_HOST_SETTINGS_PATH=
